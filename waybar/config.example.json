{
  "layer": "top",
  "position": "top",
  "modules-left": ["custom/opencode"],
  "custom/opencode": {
    "exec": "$HOME/.config/waybar/scripts/opencode-status.sh",
    "interval": 2,
    "return-type": "json",
    "format": "{icon} {text}",
    "format-icons": {
      "working": "󰒋",
      "idle": "󰄬",
      "permission": "󰀪",
      "error": "󰅙"
    },
    "tooltip": true
  }
}
